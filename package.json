{
  "name": "svelte-app",
  "version": "0.0.1303",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "deploy-app": "cd dist; ln -s ../.vercel; vc --prod",
    "release": "pnpm bump && pnpm build && pnpm deploy-app",
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "prebuild": "echo skipping pnpm format",
    "build": "vite build",
    "serve": "vite preview",
    "test": "echo skipping...",
    "cc": "prettier --check './src/**/*.{css,js,ts,svelte}'",
    "format": "prettier --write './src/**/*.{css,js,ts,svelte}'",
    "spell": "cspell 'src/**/*.{js,svelte}'",
    "open": "open https://s4e-proofs.vercel.app"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.2.0",
    "bumpp": "11.1.0",
    "cspell": "10.0.1",
    "only-allow": "1.2.2",
    "prettier": "3.9.5",
    "prettier-plugin-svelte": "4.1.1",
    "rangetouch": "2.0.1",
    "svelte": "5.56.4",
    "vite": "8.1.4",
    "yoctocolors": "2.1.2"
  },
  "packageManager": "pnpm@11.12.0+sha512.820a6fbd0d9f04c226638002aead1e45340a9139dd5dc077c1d83ef44aa2481c8eb6637b4c9aa696a3c7e35ba818e49cf27213e5f2b91138d09b7a3e26e898ba"
}
