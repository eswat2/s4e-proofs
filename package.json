{
  "name": "svelte-app",
  "version": "0.0.1273",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "deploy-app": "cd dist; ln -s ../.vercel; vc --prod",
    "release": "pnpm bump && pnpm build && pnpm deploy-app",
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "prebuild": "echo skipping pnpm format",
    "build": "vite build",
    "serve": "vite preview",
    "test": "echo skipping...",
    "cc": "prettier --check './src/**/*.{css,js,ts,svelte}'",
    "format": "prettier --write './src/**/*.{css,js,ts,svelte}'",
    "spell": "cspell 'src/**/*.{js,svelte}'",
    "open": "open https://s4e-proofs.vercel.app"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "bumpp": "11.1.0",
    "cspell": "10.0.1",
    "only-allow": "1.2.2",
    "prettier": "3.8.4",
    "prettier-plugin-svelte": "4.1.1",
    "rangetouch": "2.0.1",
    "svelte": "5.56.3",
    "vite": "8.0.16",
    "yoctocolors": "2.1.2"
  },
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620"
}
