{
  "name": "svelte-app",
  "version": "0.0.1260",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "deploy-app": "cd dist; ln -s ../.vercel; vc --prod",
    "release": "pnpm bump && pnpm build && pnpm deploy-app",
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "prebuild": "echo skipping pnpm format",
    "build": "vite build",
    "serve": "vite preview",
    "test": "echo skipping...",
    "cc": "prettier --check './src/**/*.{css,js,ts,svelte}'",
    "format": "prettier --write './src/**/*.{css,js,ts,svelte}'",
    "spell": "cspell 'src/**/*.{js,svelte}'",
    "open": "open https://s4e-proofs.vercel.app"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "bumpp": "11.1.0",
    "cspell": "10.0.0",
    "only-allow": "1.2.2",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "4.0.0",
    "rangetouch": "2.0.1",
    "svelte": "5.55.9",
    "vite": "8.0.14",
    "yoctocolors": "2.1.2"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f"
}
